<h2>💰 Multas</h2>

<form action="/multas/insertar" method="POST" class="mb-3">
    <div class="row">
        <div class="col">
            <input name="id_detalle" class="form-control" placeholder="ID Detalle">
        </div>
        <div class="col">
            <input name="detalle_texto" class="form-control" placeholder="Descripción de la multa">
        </div>
        <div class="col">
            <input name="monto" class="form-control" placeholder="Monto">
        </div>
        <div class="col">
            <button class="btn btn-success">Agregar</button>
        </div>
    </div>
</form>

<table class="table align-middle table-white table-hover table-bordered border-warning">
    <thead class="table-warning">
        <tr>
            <th>ID</th>
            <th>Detalle</th> <th>Monto</th>
            <th>Pagada</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
    <% multas.forEach(m => { %>
        <tr>
            <td><%= m.ID_MULTA %></td>
            
            <td><%= m.DETALLE_PERSONALIZADO %></td> 
            
            <td>₡<%= m.MONTO %></td>
            <td><%= m.PAGADA == 1 ? 'SÍ' : 'NO' %></td>
            
            <td>
                <form action="/multas/actualizar" method="POST" class="d-inline">
                    <input type="hidden" name="id_multa" value="<%= m.ID_MULTA %>">
                    <input type="hidden" name="pagada" value="1">
                    <button class="btn btn-warning btn-sm">Pagar</button>
                </form>

                <form action="/multas/eliminar" method="POST" class="d-inline">
                    <input type="hidden" name="id_multa" value="<%= m.ID_MULTA %>">
                    <button class="btn btn-danger btn-sm">Eliminar</button>
                </form>
            </td>
        </tr>
    <% }) %>
</tbody>
</table>