<!-- Fragmento de Devoluciones para el contenido -->

<h2>🔄 Devoluciones</h2>

<form action="/devoluciones/insertar" method="POST" class="mb-3">
    <div class="row">
        <div class="col"><input name="id_detalle" class="form-control" placeholder="ID Detalle"></div>
        <div class="col"><input name="observacion" class="form-control" placeholder="Observación"></div>
        <div class="col"><button class="btn btn-success">Agregar</button></div>
    </div>
</form>

<table class="table align-middle table-white table-hover table-bordered border-warning">
    <thead class="table-warning">
        <tr>
            <th>ID</th>
            <th>Detalle</th>
            <th>Fecha</th>
            <th>Observación</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        <% devoluciones.forEach(d=> { %>
            <tr>
                <td>
                    <%= d.ID_DEVOLUCION %>
                </td>
                <td>
                    <%= d.ID_DETALLE %>
                </td>
                <td>
                    <%= d.FECHA_DEVOLUCION %>
                </td>
                <td>
                    <%= d.OBSERVACION %>
                </td>

                <td>
                    <form action="/devoluciones/actualizar" method="POST" class="d-inline">
                        <input type="hidden" name="id_devolucion" value="<%= d.ID_DEVOLUCION %>">
                        <input type="hidden" name="observacion" value="<%= d.OBSERVACION %>">
                        <div class="d-inline-flex gap-2"><button class="btn btn-warning btn-sm">Actualizar</button>
                        </div>
                    </form>

                    <form action="/devoluciones/eliminar" method="POST" class="d-inline">
                        <input type="hidden" name="id_devolucion" value="<%= d.ID_DEVOLUCION %>">
                        <div class="d-inline-flex gap-2"><button class="btn btn-danger btn-sm">Eliminar</button>
                        </div>
                    </form>
                </td>
            </tr>
            <% }) %>
    </tbody>
</table>